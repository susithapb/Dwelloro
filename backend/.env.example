# Dwelloro - Node API environment template
# Copy to `.env` for local dev. Never commit the real .env file.

# --- MongoDB ---
# Local dev:    mongodb://localhost:27017
# Docker dev:   mongodb://mongo:27017   (service name from docker-compose)
# Atlas prod:   mongodb+srv://USER:PASS@cluster0.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb://localhost:27017
DB_NAME=dwelloro_dev

# --- Auth ---
# Must match backend/.env exactly so JWTs are interchangeable
JWT_SECRET=local-dev-secret-change-me-in-production

# --- LLM (Anthropic Claude — direct SDK) ---
# Get yours from https://console.anthropic.com/ → Settings → API Keys
# Leave the dummy value for now; AI calls will fall back to safe defaults until you add a real key.
ANTHROPIC_API_KEY=sk-ant-DUMMY-KEY-REPLACE-ME
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# --- LLM (used only for object storage init; not for Claude calls) ---
EMERGENT_LLM_KEY=

# --- App ---
APP_NAME=dwelloro
APP_PUBLIC_URL=http://localhost:3000

# --- Server port (also the port Python proxies to) ---
NODE_PORT=8002

# --- Email (Resend) — optional; if blank, contractor emails are skipped ---
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev
