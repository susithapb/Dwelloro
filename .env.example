# Dwelloro — docker-compose secrets
# Copy this file to `.env` (at the repo root) so `docker compose up` picks up your keys.
# Never commit your real .env file.

# Used to sign JWTs. Must be the same value across backend & backend-node.
JWT_SECRET=local-dev-secret-change-me-in-production

# Required for AI features (issue triage, contractor brief, inspection summary).
# Get yours from https://console.anthropic.com/ → Settings → API Keys.
# Leave as dummy for now — AI calls fall back to safe defaults until you swap in a real key.
ANTHROPIC_API_KEY=sk-ant-DUMMY-KEY-REPLACE-ME
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Legacy: only needed if you re-enable the Python gateway (Emergent preview only).
EMERGENT_LLM_KEY=

# Optional — leave blank to skip contractor assignment emails.
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev
